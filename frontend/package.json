{
  "name": "clinic-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 5173",
    "lint": "eslint \"src/**/*.{js,jsx,ts,tsx}\" --fix",
    "lint:check": "eslint \"src/**/*.{js,jsx,ts,tsx}\"",
    "audit:control-labels": "eslint \"src/**/*.{js,jsx,ts,tsx}\" --quiet --rule \"jsx-a11y/control-has-associated-label: error\"",
    "audit:icon-controls": "node scripts/audit-icon-only-controls.mjs --strict --baseline=scripts/a11y/icon-only-controls-baseline.json",
    "audit:icon-controls:strict": "node scripts/audit-icon-only-controls.mjs --strict",
    "audit:icon-controls:update-baseline": "node scripts/audit-icon-only-controls.mjs --write-baseline=scripts/a11y/icon-only-controls-baseline.json",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "check-theme": "node scripts/check-theme-compliance.js",
    "analyze": "node scripts/analyze-bundle.js",
    "build:analyze": "npm run build && npm run analyze",
    "build:visualize": "vite build --mode analyze",
    "optimize": "npm run build:analyze && npm run test:e2e:run",
    "test:e2e:run": "playwright test --reporter=html"
  },
  "dependencies": {
    "@emoji-mart/data": "^1.2.1",
    "@emoji-mart/react": "^1.1.1",
    "@emotion/babel-plugin": "^11.13.5",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@tanstack/react-virtual": "^3.13.18",
    "@vercel/speed-insights": "^2.0.0",
    "axios": "^1.16.1",
    "chart.js": "4.5.1",
    "dompurify": "^3.4.5",
    "heic2any": "^0.0.4",
    "isomorphic-dompurify": "^2.33.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "0.577.0",
    "notistack": "^3.0.2",
    "prop-types": "15.8.1",
    "qrcode.react": "4.2.0",
    "react": "18.3.1",
    "react-beautiful-dnd": "13.1.1",
    "react-datepicker": "8.10.0",
    "react-dom": "18.3.1",
    "react-dropzone": "^14.3.8",
    "react-hot-toast": "^2.4.1",
    "react-input-mask": "^2.0.4",
    "react-markdown": "^9.1.0",
    "react-router-dom": "^6.30.3",
    "react-toastify": "^11.0.5",
    "recharts": "3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@playwright/test": "^1.60.0",
    "@storybook/addon-a11y": "8.6.18",
    "@storybook/addon-docs": "8.6.18",
    "@storybook/addon-essentials": "8.6.18",
    "@storybook/addon-interactions": "8.6.18",
    "@storybook/react": "8.6.18",
    "@storybook/react-vite": "8.6.18",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/react": "18.2.0",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitejs/plugin-react": "^4.5.1",
    "@vitest/coverage-v8": "^3.2.4",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.1",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "globals": "15.15.0",
    "http-server": "14.1.1",
    "jsdom": "26.1.0",
    "rollup": "^3.30.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "terser": "^5.24.0",
    "vite": "^6.4.2",
    "vitest": "3.2.4"
  }
}
