{
  "name": "final",
  "version": "1.0.0",
  "description": "Современная система управления медицинской клиникой с полным функционалом для записи пациентов, управления очередями, обработки платежей и ведения медицинских карт.",
  "private": true,
  "directories": {
    "doc": "docs"
  },
  "dependencies": {
    "@babel/parser": "^7.29.7",
    "@babel/traverse": "^7.29.7",
    "@babel/types": "^7.29.7",
    "glob": "^13.0.6"
  },
  "scripts": {
    "dev": "cd frontend && npm run dev",
    "build": "cd frontend && npm run build",
    "preview": "cd frontend && npm run preview",
    "test": "cd frontend && npm run test:run",
    "test:frontend": "cd frontend && npm run test:run",
    "landing:init": "python scripts/landing_factory/scaffold_run.py",
    "landing:pipeline": "python scripts/landing_factory/run_pipeline.py",
    "landing:scorecard": "python scripts/landing_factory/aggregate_scorecard.py",
    "check-auth": "cd backend && python test_role_routing.py",
    "check-system": "cd backend && python check_system_integrity.py",
    "remind-rules": "python scripts/remind_auth_rules.py",
    "pre-commit": "npm run check-auth && npm run check-system"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/drsapaev/final.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/drsapaev/final/issues"
  },
  "homepage": "https://github.com/drsapaev/final#readme"
}
