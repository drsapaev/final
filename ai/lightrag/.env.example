# Optional LightRAG DevBrain settings.
# No-key fallback is the default and does not need any external API.

LIGHTRAG_STORAGE_DIR=ai/lightrag/indexes/lightrag_graph
LIGHTRAG_MANIFEST=ai/lightrag/data/manifest.json
LIGHTRAG_TOP_K=8
LIGHTRAG_PROVIDER=fallback

# Optional isolated dev-brain provider bridge.
# Do not use ChatGPT Plus or Codex app credentials as API keys.
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat
