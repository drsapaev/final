# Optional local overrides for DevBrain LlamaIndex retrieval.
# The fallback scripts run without API keys.

LLAMAINDEX_STORAGE_DIR=ai/llamaindex/storage
LLAMAINDEX_MANIFEST=ai/llamaindex/data/manifest.json
LLAMAINDEX_TOP_K=8

# Optional future provider settings. Leave unset for no-key fallback mode.
# OPENAI_API_KEY=
# LLAMAINDEX_USE_EXTERNAL_LLM=0
