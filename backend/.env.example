ENV=dev
APP_NAME="Clinic Queue Manager"
APP_VERSION="0.9.0"
API_V1_STR=/api/v1
TIMEZONE=Asia/Tashkent

# CORS: when allow-all mode is enabled, the origin list is ignored.
CORS_DISABLE=0
CORS_ALLOW_ALL=0
# через запятую; должен совпадать с адресами фронта
CORS_ORIGINS=http://localhost:5173,http://localhost:4173,http://localhost:4174,http://localhost:8080,http://127.0.0.1:5173,http://127.0.0.1:4173,http://127.0.0.1:4174,http://127.0.0.1:8080

# Database
DATABASE_URL=

# Auth / JWT
# Required. Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Tenant scope guard for branch-owned write endpoints
TENANT_SCOPE_ENFORCE_WRITES=0
TENANT_SCOPE_WRITE_PREFIXES=/api/v1/billing,/api/v1/queue,/api/v1/emr,/api/v1/v2/emr,/api/v1/clinic/equipment

# Printing / PDFs
CLINIC_LOGO_PATH=
PDF_FOOTER_ENABLED=1

# ESC/POS printer
PRINTER_TYPE=none        # none|network|usb
PRINTER_NET_HOST=
PRINTER_NET_PORT=9100
PRINTER_USB_VID=
PRINTER_USB_PID=

# Licensing
REQUIRE_LICENSE=0
LICENSE_ALLOW_HEALTH=1

# Docker Compose / staging alternative:
# DB_HOST=postgres
# DB_PORT=5432
# DB_USER=clinic
# DB_PASSWORD=
# DB_NAME=clinicdb
# DATABASE_URL=postgresql+psycopg://clinic:<db_password>@postgres:5432/clinicdb

# ===== Redis (на будущее) =====
# REDIS_URL=redis://redis:6379/0
