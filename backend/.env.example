# Development-first backend env template
# Copy to backend/.env for local/dev.
# For production/ops, also review:
# - backend/SETUP_PRODUCTION.md
# - backend/PRODUCTION_SETUP_SUMMARY.md
# - ops/.env.example
#
# Current caveat:
# - active backend config validates SECRET_KEY
# - legacy AUTH_SECRET is intentionally NOT part of this backend template

ENV=dev
APP_NAME="Clinic Queue Manager"
APP_VERSION="0.9.0"
API_V1_STR=/api/v1
TIMEZONE=Asia/Tashkent
LOG_LEVEL=INFO
LOG_STRUCTURED=1

# CORS: if CORS_ALLOW_ALL=1, the origins list is ignored.
# Backend currently accepts both CORS_ORIGINS and BACKEND_CORS_ORIGINS;
# this template keeps the simpler CORS_ORIGINS form for local/dev.
CORS_DISABLE=0
CORS_ALLOW_ALL=0
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
FRONTEND_URL=http://localhost:5173

# Database
DATABASE_URL=sqlite:///./clinic.db

# Startup helpers
# App startup now assumes schema is prepared explicitly (for example:
# `alembic upgrade head`). `ENSURE_ADMIN` is only used by the ops entrypoint or
# explicit bootstrap commands.
ENSURE_ADMIN=0
ADMIN_ALLOW_UPDATE=0

# Auth / JWT
SECRET_KEY=change_me_please_64chars_minimum________________________________
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Tenant scope guard for branch-owned write endpoints
TENANT_SCOPE_ENFORCE_WRITES=0
TENANT_SCOPE_WRITE_PREFIXES=/api/v1/billing,/api/v1/queue,/api/v1/emr,/api/v1/v2/emr,/api/v1/clinic/equipment

# Printing / PDFs
CLINIC_LOGO_PATH=
PDF_FOOTER_ENABLED=1

# ESC/POS printer
PRINTER_TYPE=none        # none|network|usb
PRINTER_NET_HOST=
PRINTER_NET_PORT=9100
PRINTER_USB_VID=
PRINTER_USB_PID=

# Licensing
REQUIRE_LICENSE=0
LICENSE_ALLOW_HEALTH=1

# Optional backups
AUTO_BACKUP_ENABLED=0
BACKUP_HOUR=2
BACKUP_MINUTE=0
BACKUP_RETENTION_DAYS=30

# Optional Firebase Cloud Messaging (FCM)
# FCM_ENABLED=0
# FCM_SERVER_KEY=
# FCM_SENDER_ID=
# FCM_PROJECT_ID=

# Postgres example for non-local deployment:
# DATABASE_URL=postgresql+psycopg://clinic:clinicpwd@postgres:5432/clinicdb
#
# For compose interpolation variables such as POSTGRES_USER/POSTGRES_PASSWORD,
# see ops/.env.example.

# ===== Redis (future / optional) =====
# REDIS_URL=redis://redis:6379/0
