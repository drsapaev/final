# Shared lifecycle env for clinic-host and VPS rehearsal scripts

# Optional override if you keep the file elsewhere:
# LIFECYCLE_ENV_FILE=/opt/clinic/.env.clinic-lifecycle

APP_ENV=production
APP_ROOT=/opt/clinic
APP_HOST=clinic.example.com
BACKEND_URL=http://127.0.0.1:18000
PUBLIC_URL=https://clinic.example.com
# Required. Use the password created by bootstrap_postgres.sh.
DATABASE_URL=

BACKUP_DIR=/opt/clinic/output/backups

# Fresh install setup payload (either use these fields or SETUP_PAYLOAD_FILE / SETUP_PAYLOAD_JSON)
SETUP_CLINIC_NAME=Clinic Name
SETUP_CLINIC_ADDRESS=
SETUP_CLINIC_PHONE=
SETUP_CLINIC_EMAIL=
SETUP_CLINIC_TIMEZONE=Asia/Tashkent
SETUP_CLINIC_LOGO_URL=

SETUP_BRANCH_NAME=Main Branch
SETUP_BRANCH_CODE=main
SETUP_BRANCH_ADDRESS=
SETUP_BRANCH_PHONE=
SETUP_BRANCH_EMAIL=
SETUP_BRANCH_TIMEZONE=Asia/Tashkent
SETUP_BRANCH_CAPACITY=50

SETUP_ADMIN_USERNAME=admin
# Required. Use a unique first-run admin password.
SETUP_ADMIN_PASSWORD=
SETUP_ADMIN_FULL_NAME=Clinic Admin
SETUP_ADMIN_EMAIL=admin@example.com
SETUP_ACTIVATION_KEY=

# Optional smoke login override
SMOKE_LOGIN_USERNAME=
SMOKE_LOGIN_PASSWORD=
SMOKE_REQUIRE_LOGIN=1

# Frontend runtime probe defaults to same-origin.
# Only set FRONTEND_EXPECT_SPLIT_ORIGIN=1 when you intentionally deploy split-origin.
# Optional explicit expectations:
# EXPECTED_FRONTEND_API_ORIGIN=https://api.example.com
# EXPECTED_FRONTEND_WS_ORIGIN=wss://api.example.com
FRONTEND_EXPECT_SPLIT_ORIGIN=0

# Update rehearsal
# Use either:
# - an approved git release ref from the online release source
# - an imported ref emitted by import_release_artifact.py for offline delivery
UPDATE_RELEASE_REF=
ROLLBACK_REF=
ROLLBACK_RUN_MIGRATIONS=0

# Restore rehearsal target
RESTORE_DATABASE_URL=
RESTORE_BACKEND_URL=
RESTORE_PUBLIC_URL=
