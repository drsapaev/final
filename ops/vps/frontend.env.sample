# Frontend runtime is same-origin first for /api and /ws.
# Leave these unset for the normal one-build-per-product deployment model.
# Only set VITE_API_BASE_URL when you intentionally run the frontend against a separate API origin.
# `localhost` is for internal health/backend checks only and must not be the official clinic URL.

# Optional split-origin override example:
# VITE_API_BASE_URL=https://api.example.com
