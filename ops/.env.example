# ===========================================
# Clinic Management System - Environment Variables
# ===========================================
# Compose interpolation example for ops/docker-compose.yml
# This file does NOT replace backend/.env.production.
# The current compose file still expects backend/.env.production for backend
# runtime settings via env_file.
#
# Current caveat:
# - compose still interpolates AUTH_SECRET
# - active backend config validates SECRET_KEY
# Set SECRET_KEY in backend/.env.production and treat AUTH_SECRET below as
# legacy compose residue until compose wiring is cleaned up.

# -------------------------------------------
# Database
# -------------------------------------------
# Default: PostgreSQL (recommended for prod)
DATABASE_URL=postgresql+psycopg://clinic:clinicpwd@localhost:5432/clinicdb
POSTGRES_USER=clinic
POSTGRES_PASSWORD=clinicpwd
POSTGRES_DB=clinicdb
# Explicit SQLite override (dev only): DATABASE_URL=sqlite:////data/app.db

# -------------------------------------------
# Application
# -------------------------------------------
APP_NAME=Clinic Queue Manager
APP_VERSION=0.9.0
ENV=production
# ENV options: dev, staging, production
LOG_LEVEL=INFO
LOG_STRUCTURED=1

# -------------------------------------------
# Observability / SLA
# -------------------------------------------
OBS_SLA_WINDOW_SECONDS=300
OBS_SLA_LATENCY_P95_MS=1200
OBS_SLA_ERROR_RATE_PCT=5
OBS_SLA_QUEUE_LAG_MAX=50

# -------------------------------------------
# Security / Authentication
# -------------------------------------------
# CRITICAL: backend runtime validates SECRET_KEY
SECRET_KEY=change-me-in-production-use-secrets-token-urlsafe-32
# Legacy compose variable still referenced by ops/docker-compose.yml
AUTH_SECRET=change-me-in-prod
ACCESS_TOKEN_EXPIRE_MINUTES=720
REFRESH_TOKEN_EXPIRE_DAYS=7

# -------------------------------------------
# CORS Configuration
# -------------------------------------------
# CORS_ALLOW_ALL=1 is for local/dev only
CORS_ALLOW_ALL=0
# backend currently accepts both CORS_ORIGINS and BACKEND_CORS_ORIGINS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# -------------------------------------------
# Admin User (Bootstrap)
# -------------------------------------------
# Explicit opt-in only. Startup no longer bootstraps admin unless
# ENSURE_ADMIN=1 is set intentionally.
ENSURE_ADMIN=0
# Existing-user mutation also requires explicit opt-in.
ADMIN_ALLOW_UPDATE=0
# Dev convenience defaults only - review before non-local use
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
ADMIN_EMAIL=admin@example.com
ADMIN_FULL_NAME=Administrator
ADMIN_RESET_PASSWORD=0

# -------------------------------------------
# Server Configuration
# -------------------------------------------
HOST=0.0.0.0
PORT=8000
RELOAD=0
WORKERS=2

# -------------------------------------------
# Printer Configuration (optional)
# -------------------------------------------
PRINTER_TYPE=none
# PRINTER_TYPE options: none, network, usb
PRINTER_NET_HOST=
PRINTER_NET_PORT=9100
PRINTER_USB_VID=
PRINTER_USB_PID=

# -------------------------------------------
# Licensing / Activation
# -------------------------------------------
REQUIRE_LICENSE=1
LICENSE_MODE=activation
LICENSE_ALLOW_HEALTH=1

# -------------------------------------------
# Backups
# -------------------------------------------
AUTO_BACKUP_ENABLED=1
BACKUP_HOUR=2
BACKUP_MINUTE=0

# -------------------------------------------
# Frontend (Vite)
# -------------------------------------------
# Frontend dev server default
VITE_API_BASE=http://localhost:8000/api/v1
VITE_API_URL=http://localhost:8000

# -------------------------------------------
# Optional: External Services
# -------------------------------------------
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# SMS_PROVIDER=
# SMS_API_KEY=
# CLICK_MERCHANT_ID=
# CLICK_SERVICE_ID=
# CLICK_SECRET_KEY=
# PAYME_MERCHANT_ID=
# PAYME_SECRET_KEY=
# SENTRY_DSN=

# -------------------------------------------
# AI Providers
# -------------------------------------------
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
# DEEPSEEK_API_KEY=sk-...
# GROK_API_KEY=xai-...

# -------------------------------------------
# Encryption (AES-256)
# -------------------------------------------
# ENCRYPTION_KEY=your-32-char-secret-key-here

# -------------------------------------------
# External Integrations
# -------------------------------------------
# DMED (Medical Information System)
# DMED_API_KEY=
# DMED_BASE_URL=https://api.dmed.uz/v1
# DMED_CLINIC_ID=

# eGOV (Electronic Government)
# EGOV_API_KEY=
# EGOV_BASE_URL=https://api.egov.uz/v1

# Insurance
# INSURANCE_DEFAULT_API_KEY=
# INSURANCE_DEFAULT_BASE_URL=

# ECG Upload Directory
# ECG_UPLOAD_DIR=uploads/ecg
